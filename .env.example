# Zebrunner MCP Server Configuration
# Copy this file to .env and uncomment the section matching your mode.
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ Mode 1 (STDIO):        Local install, credentials in env vars  │
# │ Mode 2 (HTTP+Headers): Remote, creds in client X-Zebrunner-*   │
# │ Mode 3 (Self-Service): Remote, URL only, one-time login form   │
# │ Mode 4 (Okta):         Remote, URL only, Okta + login form     │
# └─────────────────────────────────────────────────────────────────┘

# === COMMON (all modes) ===
ZEBRUNNER_URL=https://your-workspace.zebrunner.com/api/public/v1

# === TRANSPORT (pick one) ===
# MCP_TRANSPORT=stdio            # Mode 1 — default when PORT is not set
# MCP_TRANSPORT=http             # Modes 2-4 — auto-detected when PORT is set
# PORT=3000                      # Required for HTTP modes

# ─── MODE 1: STDIO (local install) ───────────────────────────────
# Credentials loaded at startup. Each user runs their own instance.
# ZEBRUNNER_LOGIN=your.email@company.com
# ZEBRUNNER_TOKEN=your-api-token

# ─── MODE 2: HTTP + Headers ──────────────────────────────────────
# Simplest HTTP mode. Each client sends creds via X-Zebrunner-* headers.
# No server-side secrets needed beyond ZEBRUNNER_URL.
# MCP_AUTH_MODE=headers

# ─── MODE 3: Self-Service OAuth (no Okta needed) ─────────────────
# Users enter Zebrunner credentials once via a browser form.
# Server stores them encrypted — subsequent connections are automatic.
# MCP_AUTH_MODE=selfauth
# TOKEN_STORE_PATH=./data/tokens.enc
# TOKEN_STORE_KEY=any-strong-secret-for-encryption
# OAUTH_FLOW_STORE_DIR=/data/oauth-flow  # optional; default: dirname(TOKEN_STORE_PATH)/oauth-flow

# ─── MODE 4: Okta OAuth + per-user credentials ───────────────────
# Okta SSO as access gate + per-user Zebrunner credential form.
# No ZEBRUNNER_LOGIN/TOKEN needed on the server.
# MCP_AUTH_MODE=okta
# TOKEN_STORE_PATH=./data/tokens.enc
# TOKEN_STORE_KEY=any-strong-secret-for-encryption
# OKTA_DOMAIN=your-org.okta.com
# OKTA_CLIENT_ID=0oa...
# OKTA_CLIENT_SECRET=your-client-secret
# OKTA_AUTH_SERVER_ID=default
# MCP_SERVER_URL=https://mcp.company.internal   # Public URL for OAuth metadata

# ─── Combined modes ──────────────────────────────────────────────
# Accept headers OR OAuth (useful during migration):
# MCP_AUTH_MODE=headers,selfauth
# MCP_AUTH_MODE=headers,okta

# === OPTIONAL ===
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=10
DEBUG=false

# ── MCP Resources ──
# Comma-separated project keys to expose as resources (e.g. ANDROID,IOS,WEB).
# When unset, only starred projects are listed. No resources if none match.
# MCP_RESOURCE_PROJECTS=ANDROID,IOS,WEB

# ── Local HTTP development ──
# Allow HTTP (non-HTTPS) issuer URLs for OAuth metadata discovery.
# Required for local testing with Modes 3–4 over plain http://localhost.
# Do NOT enable in production behind a TLS proxy.
# MCP_DANGEROUSLY_ALLOW_INSECURE_ISSUER_URL=true

# JIRA_BASE_URL=https://your-project.atlassian.net
# ENABLE_RULES_ENGINE=true

# ── Legacy tool-name aliases (rollback only) ──
# As of v9.0.0 every tool is registered ONLY under its adv_<name> form
# (e.g. adv_create_test_case). Set this to "true" if you cannot migrate
# prompts/scripts/agent rules immediately — each old short name will be
# re-registered as a deprecated alias that routes to the same handler.
# This escape hatch will be removed in a future major release.
# ZEBRUNNER_REGISTER_LEGACY_ALIASES=false

# ── Instance Config Override (Docker / CI / K8s) ──
# Override zebrunner-config.json without a volume mount.
# Priority: ZEBRUNNER_CONFIG_JSON > /config/zebrunner-config.json > ZEBRUNNER_CONFIG_PATH > CWD
#
# Inline JSON (entire config as a string — useful in K8s ConfigMaps or CI secrets):
# ZEBRUNNER_CONFIG_JSON={"projectAliases":{"web":"PROJ1","android":"PROJ2"},"testConnectionProjectKey":"PROJ1"}
#
# Custom file path (when the config lives outside the default locations):
# ZEBRUNNER_CONFIG_PATH=/opt/configs/zebrunner-config.json

# ── LLM Evaluation Testing (optional) ──
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# EVAL_MODEL=claude-sonnet-4-6
# EVAL_LAYER=3
