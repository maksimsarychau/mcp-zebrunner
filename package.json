{
  "name": "mcp-zebrunner",
  "version": "9.1.0",
  "type": "module",
  "description": "Advanced Zebrunner MCP Server — analytics, reporting, and safe mutations for Zebrunner. Complements the official Zebrunner MCP (beta). Tools registered as adv_<name> with legacy aliases kept for backward compatibility.",
  "mcpName": "io.github.maksimsarychau/mcp-zebrunner",
  "main": "dist/index.js",
  "author": "Maksim Sarychau",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maksimsarychau/mcp-zebrunner.git"
  },
  "keywords": [
    "zebrunner",
    "tcm",
    "qa",
    "testing",
    "reporting",
    "dashboards",
    "mcp",
    "model-context-protocol"
  ],
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE.md",
    "mcp-zebrunner-rules.md.example",
    ".integrity-signature"
  ],
  "scripts": {
    "version": "node -p \"require('./package.json').version\"",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "deploy": "node scripts/increment-version.js && tsc -p tsconfig.json",
    "release": "tsc -p tsconfig.json && tsc --noEmit && tsx tests/test-runner.ts all",
    "release:with-increment": "node scripts/increment-version.js && tsc -p tsconfig.json && tsc --noEmit && tsx tests/test-runner.ts all",
    "increment": "node scripts/increment-version.js",
    "sync-versions": "node scripts/increment-version.js --sync",
    "start": "node dist/server.js",
    "smoke": "tsx tests/smoke/smoke.ts",
    "test": "tsx tests/test-runner.ts all",
    "test:unit": "tsx tests/test-runner.ts unit",
    "test:integration": "tsx tests/test-runner.ts integration",
    "test:e2e": "tsx tests/test-runner.ts e2e",
    "test:hierarchy": "node --test --test-reporter=spec --import=tsx tests/integration/suite-hierarchy.test.ts",
    "test:reporting": "node --test --test-reporter=spec --import=tsx tests/integration/reporting-api.test.ts",
    "test:watch": "tsx tests/test-runner.ts all --watch",
    "test:health": "tsx tests/test-runner.ts --health",
    "test:api": "bash tests/api-verify.sh",
    "test:eval": "tsx tests/test-runner.ts eval",
    "test:eval:l1": "EVAL_LAYER=1 tsx tests/test-runner.ts eval",
    "test:eval:l2": "EVAL_LAYER=2 tsx tests/test-runner.ts eval",
    "test:eval:l3": "EVAL_LAYER=3 tsx tests/test-runner.ts eval",
    "test:eval:debug": "tsx tests/test-runner.ts eval",
    "test:verbose": "tsx tests/test-runner.ts all --verbose",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "inspector": "npx @modelcontextprotocol/inspector -- npx tsx src/server.ts",
    "dev:debug": "DEBUG=true tsx watch src/server.ts",
    "sign-release": "tsx scripts/sign-release.ts",
    "update-control": "tsx scripts/update-control.ts",
    "docker:build:multiarch": "bash scripts/docker-build-push.sh"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "node-addon-api": "^8.8.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/generative-ai": "^0.24.1",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^25.9.1",
    "node-gyp": "^11.5.0",
    "openai": "^6.39.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
